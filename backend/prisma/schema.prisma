generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model TemperatureReadings {
  id String @id @default(uuid())
  deviceId String
  temperature Float
  sentAt DateTime

  createdAt DateTime @default(now())

  @@index([deviceId])
  @@map("temperature_readings")
}